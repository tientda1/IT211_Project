                  "listen": "test",
                  "script": {
                    "exec": [
                      "var jsonData = pm.response.json();",
                      "if (jsonData.data) {",
                      "    var token = jsonData.data.accessToken || jsonData.data.access_token;",
                      "    var rToken = jsonData.data.refreshToken || jsonData.data.refresh_token;",
                      "    if (token) pm.collectionVariables.set(\"accessToken\", token);",
